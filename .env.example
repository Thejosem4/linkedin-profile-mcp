# ─────────────────────────────────────────────
# LinkedIn Profile MCP — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LinkedIn OAuth ──────────────────────────
# Get these from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Server ───────────────────────────────────
PORT=3000
# Options: debug | info | warn | error
LOG_LEVEL=info

# ── User Context (personalizes AI suggestions)
# Sector: your industry (e.g. technology, finance, healthcare)
USER_SECTOR=technology

# Objective options: job_search | personal_brand | freelance | promotion
USER_OBJECTIVE=job_search

# Audience options: recruiters | clients | peers | general
USER_AUDIENCE=recruiters

# Tone options: formal | conversacional | técnico
USER_TONE=conversacional

# Profile language: en | es | fr | de | pt
PROFILE_LANGUAGE=en
